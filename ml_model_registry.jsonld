      "id": "urn:ngsi-ld:MLModel:OccupancyDetector",
      "type": "MLModel",
      "name": {
        "type": "Property",
        "value": "Occupancy Detector"
      },
      "description": {
        "type": "Property",
        "value": "Predicts occupancy level from motion sensor data [LEVEL 0]"
      },
      "modelType": {
        "type": "Property",
        "value": "RandomForestRegressor"
      },
      "inputs": {
        "type": "Property",
        "value": [
          {
            "name": "Kitchen_occupancy",
            "type": "Number",
            "source": "urn:ngsi-ld:Sensor:Kitchen:Motion"
          },
          {
            "name": "Lab_occupancy",
            "type": "Number",
            "source": "urn:ngsi-ld:Sensor:Lab:Motion"
          },
          {
            "name": "Mailroom_occupancy",
            "type": "Number",
            "source": "urn:ngsi-ld:Sensor:Mailroom:Motion"
          },
          {
            "name": "occ_lag1",
            "type": "Number",
            "source": "derived"
          }
        ]
      },
      "outputs": {
        "type": "Property",
        "value": [
          {
            "name": "predicted_occupancy",
            "type": "Number",
            "description": "Occupancy level (0-1)"
          }
        ]
      },
      "modelPath": {
        "type": "Property",
        "value": "ml_models/occupancy_detector.pkl"
      },
      "metrics": {
        "type": "Property",
        "value": {
          "r2_score": 0.809,
          "mae": 0.026,
          "trainingSamples": 104
        }
      }
    },
